{
  "name": "react-gpt-hooks",
  "version": "1.0.2",
  "description": "Modern React hooks & components for Google Publisher Tag (GPT) ads. TypeScript-first, zero dependencies, SSR/Next.js ready.",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck",
    "example:basic": "cd examples/basic && npm run dev",
    "example:nextjs": "cd examples/nextjs && npm run dev"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "react",
    "gpt",
    "google-publisher-tag",
    "ads",
    "dfp",
    "doubleclick",
    "typescript",
    "ssr",
    "nextjs"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": ""
}
